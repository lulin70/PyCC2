{"$schema": "http://json-schema.org/draft-07/schema#", "title": "Unit Template Schema", "description": "Schema for PyCC2 unit template definitions", "type": "object", "required": ["id", "name", "faction", "unit_type", "size", "stats", "weapon", "movement", "vision"], "properties": {"id": {"type": "string", "pattern": "^[a-z_]+$"}, "name": {"type": "string"}, "faction": {"type": "string", "enum": ["allied", "axis"]}, "unit_type": {"type": "string", "enum": ["infantry", "vehicle", "support"]}, "size": {"type": "object", "properties": {"min_personnel": {"type": "integer", "minimum": 1}, "max_personnel": {"type": "integer", "minimum": 1}}}, "stats": {"type": "object", "required": ["health", "morale", "experience"], "properties": {"health": {"type": "integer", "minimum": 1}, "morale": {"type": "integer", "minimum": 0, "maximum": 100}, "experience": {"type": "string", "enum": ["recruit", "regular", "veteran", "elite"]}}}, "weapon": {"type": "object", "required": ["name", "type", "damage_range", "range_meters", "rof", "accuracy"], "properties": {"name": {"type": "string"}, "type": {"type": "string", "enum": ["rifle", "smg", "lmg", "pistol", "grenade"]}, "damage_range": {"type": "object", "properties": {"min": {"type": "number"}, "max": {"type": "number"}}}, "range_meters": {"type": "number"}, "rof": {"type": "number", "description": "Rounds per minute"}, "accuracy": {"type": "number", "minimum": 0, "maximum": 1}}}, "movement": {"type": "object", "required": ["speed_tiles_per_turn", "terrain_cost_modifiers"], "properties": {"speed_tiles_per_turn": {"type": "number"}, "terrain_cost_modifiers": {"type": "object", "additionalProperties": {"type": "number"}}}}, "vision": {"type": "object", "required": ["range_tiles", "fov_angle_degrees"], "properties": {"range_tiles": {"type": "number"}, "fov_angle_degrees": {"type": "number"}}}, "abilities": {"type": "array", "items": {"type": "string"}}, "special_rules": {"type": "array", "items": {"type": "string"}}}}