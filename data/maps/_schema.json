{"$schema": "http://json-schema.org/draft-07/schema#", "title": "GameMap Schema", "description": "Schema for PyCC2 tactical map definitions", "type": "object", "required": ["name", "width", "height", "terrain", "spawn_points"], "properties": {"name": {"type": "string", "description": "Map display name"}, "width": {"type": "integer", "minimum": 8, "maximum": 64, "description": "Map width in tiles"}, "height": {"type": "integer", "minimum": 8, "maximum": 64, "description": "Map height in tiles"}, "terrain": {"type": "array", "items": {"type": "array", "items": {"type": "string", "enum": ["grass", "road", "forest", "water", "building", "hill", "trench", "wall"]}}, "description": "2D terrain grid"}, "spawn_points": {"type": "object", "properties": {"allied": {"type": "array", "items": {"type": "object", "required": ["x", "y"], "properties": {"x": {"type": "integer"}, "y": {"type": "integer"}}}}, "axis": {"type": "array", "items": {"type": "object", "required": ["x", "y"], "properties": {"x": {"type": "integer"}, "y": {"type": "integer"}}}}}}}, "objectives": {"type": "array", "items": {"type": "object", "properties": {"id": {"type": "string"}, "position": {"type": "object"}, "type": {"type": "string", "enum": ["capture", "defend", "reach"]}, "description": {"type": "string"}}}}, "victory_conditions": {"type": "object", "properties": {"eliminate_all_enemies": {"type": "boolean"}, "capture_objectives": {"type": "boolean"}, "turn_limit": {"type": "integer"}}}}}